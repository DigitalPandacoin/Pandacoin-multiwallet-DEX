{
  "name": "komodo-wallet-desktop",
  "version-string": "0.8.2",
  "dependencies": [
    "boost-multiprecision",
    "boost-filesystem",
    "boost-thread",
    "boost-random",
    "boost-lockfree",
    "boost-stacktrace",
    "doctest",
    {
      "name": "entt",
      "version": "3.5.1"
    },
    {
      "name": "fmt",
      "version": "7.1.3"
    },
    "nlohmann-json",
    "range-v3",
    "libsodium",
    "spdlog",
    {
      "name": "spdlog",
      "features": [
        "wchar",
        "wchar-filenames"
      ],
      "platform": "windows"
    },
    {
      "name": "date",
      "features": [
        "remote-api"
      ],
      "platform": "windows"
    },
    "date",
    "cpprestsdk"
  ]
}
